# --- Ambiente ---
ENV=development
LOG_LEVEL=INFO
RANDOM_SEED=42

# --- Dados ---
RAW_DATA_DIR=data/raw
PROCESSED_DATA_DIR=data/processed
MODELS_DIR=models
EVENTS_FILE=events.csv
ITEM_PROPERTIES_FILE=item_properties.csv
CATEGORY_TREE_FILE=category_tree.csv

# --- Pesos de feedback implícito (relevância diferenciada p/ NDCG) ---
WEIGHT_VIEW=1.0
WEIGHT_ADDTOCART=3.0
WEIGHT_TRANSACTION=5.0

# --- Modelo Two-Tower ---
EMBEDDING_DIM=64
NEGATIVE_SAMPLES_PER_POSITIVE=4
LEARNING_RATE=0.001
BATCH_SIZE=1024
MAX_EPOCHS=50
EARLY_STOPPING_PATIENCE=5

# --- Avaliação ---
TOP_K=10

# --- MLflow ---
MLFLOW_TRACKING_URI=http://localhost:5000
MLFLOW_EXPERIMENT_NAME=retailrocket-two-tower
MLFLOW_REGISTERED_MODEL_NAME=twinrank-ai-two-tower

# --- API ---
API_HOST=0.0.0.0
API_PORT=8000
MODEL_STAGE=Production
MODEL_PATH=models/two_tower/model.joblib
